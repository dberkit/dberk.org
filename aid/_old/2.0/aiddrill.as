class aiddrill {		static private var drillInstance:XMLNode;	static private var idiomDrillNode:XMLNode;		static private var drillHilightColor:Number = 0xCCEBFF; // 0xFFFFCC;		static var selectedInstance:String;		static var imageArray:Array = new Array();	static var columnArray:Array = new Array();		static var drillGridListener:Object = new Object();	static var drillsExitListener:Object = new Object();		static var idiomDataProvider:Array;		static var topicName:String;		static var drillFileList:Array;	static var shuffledDrillFileList:Array;		static var currentDrillNum:Number;	static var numPlaybackAttempts:Number;	static var numHearings:Number;	static var selectedIdiom:String;	static var selectedIdiomText:String;	static var correctIdiomText:String;	static var correctIdiom:String;		static var auto_play:Boolean = false; // if set to true, then the first drill hearing will auto-play		static var drillScoreArray:Array = new Array();	static var pastDrillScoreArrays:Array = new Array();		// constructor	function aiddrill(drl:XMLNode, idm:Array, topic:String, drList:Array, numHear:Number) {		_root.drillDialog._visible = false;		_root.levelCombo.enabled = true;		_root.topicCombo.enabled = true;		_root.idiomGrid.enabled = true;		_root.drillGrid.enabled = true;		//_root.notationGrid.enabled = true;		_root.ignorePlaybackRequests = false;				drillInstance = drl;		idiomDataProvider = idm;		topicName = topic;		drillFileList = drList;		currentDrillNum = 0;		numPlaybackAttempts = 0;		numHearings = numHear;						_root.nextFrame();		_root.onEnterFrame = function () {			for (var i:Number = 0; i<1; i++) {				getIdiomList();			}			delete _root.onEnterFrame;		};	}		static private function getIdiomList() {				_root.drill_submit.enabled = false;				_root.play_btn.enabled = true		_root.play_btn._alpha = 100;		_root.drillscore_correct.text = "";		_root.drillscore_percent.text = "";				_root.num_hearings.text = "0/" + numHearings;				unfillPlayProgressBar();				_root.topic_name.text = topicName;		_root.drill_name.text = "Drill: " + drillInstance.attributes.name;				_root.drillGrid.removeAllColumns();		_root.drillGrid.removeAll();		_root.drillGrid.columnNames = ["data", "label"];				_root.drillGrid.setStyle("rollOverColor", 0xCCCCCC);		_root.drillGrid.setStyle("selectionColor", drillHilightColor);		HtmlCellRenderer.CssUrl = "mycss.css";		_root.drillGrid.embedFonts = true;						var col:mx.controls.gridclasses.DataGridColumn;		col = _root.drillGrid.getColumnAt(1);		col.width = 565;		col.headerText = "Idioms";		col.cellRenderer = "HtmlCellRenderer";						_root.drillGrid.dataProvider = idiomDataProvider;				//trace("idiom data provider: ");		for(var zz=0; zz<idiomDataProvider.length; zz++) {			//trace(idiomDataProvider[zz].data);		}				// grid cleanup		_root.drillGrid.removeColumnAt(_root.drillGrid.getColumnIndex("data"));		//_root.drillGrid.setStyle("alternatingRowColors", Array(0xFFFFFF, 0xF7F7F7));		_root.drillGrid.rowHeight = 28;										drillGridListener.change = function (evt_obj:Object) {			//trace("Selected idiom is: " + evt_obj.target.selectedItem.data);						if(evt_obj.target.selectedItem.data) {				//trace("selection is: " + evt_obj.target.selectedItem.data.attributes.id);				selectedIdiom = evt_obj.target.selectedItem.data;				selectedIdiomText = evt_obj.target.selectedItem.label;			}			else {				trace("selected idiom has no data");			}		};		_root.drillGrid.addEventListener("change", drillGridListener)				// Setup Exit Drill button		_root.exit_drill.onRelease = function() {			exitDrill();		}				// Setup Submit button		_root.drill_submit.onRelease = function() {			submitExample();		}						// Setup Submit button		_root.cadence_btn.onRelease = function() {			playCadence();		}						// Setup Submit button		_root.play_btn.onRelease = function() {			playExample();		}				shuffledDrillFileList = shuffleDrillList(drillFileList);		//trace("shuffledDrillFileList:\r" + shuffledDrillFileList + "\r");				if(auto_play) {playExample();}	}			static private function playExample() {				_root.drill_submit.enabled = true; // enable the submit button after playback				var i:Number;				if (numPlaybackAttempts >= numHearings) {			//trace("no more hearings!");		}		else {			correctIdiom = shuffledDrillFileList[currentDrillNum].substr(0,3);						// this is the 4a drill #2 exception						if (drillInstance.attributes.name == "Comparison of bII6, ii°6, ii6") {				var char3:String = shuffledDrillFileList[currentDrillNum].substr(2,1);								if(char3=="a" || char3 =="b" || char3=="c" || char3=="d" ){					correctIdiom = "4aa-4ad";				}				if(char3=="e" || char3 =="f" || char3=="g" || char3=="h" ){					correctIdiom = "4ae-4ah";				}				if(char3=="i" || char3 =="j" || char3=="k" || char3=="l" ){					correctIdiom = "4ai-4al";				}			}						for(i=0; i<idiomDataProvider.length; i++) {								if (idiomDataProvider[i].data == correctIdiom) {					break;				}							}						correctIdiomText = idiomDataProvider[i].label;						//trace("playing: " + shuffledDrillFileList[currentDrillNum]);			//trace("numPlaybackAttempts: " + numPlaybackAttempts);						_root.instanceSound.onLoad = function(success:Boolean):Void {				if (success && !_root.isPlaying) {						_root.cadenceSound.stop();					_root.cadence_btn.enabled = false;					_root.cadence_btn._alpha = 50;					_root.instanceSound.start();					_root.isPlaying = true;					numPlaybackAttempts++;					_root.num_hearings.text = numPlaybackAttempts + "/" + numHearings;										fillPlayProgressBar();										_root.instanceSound.onSoundComplete = function () {					_root.isPlaying = false;					_root.cadence_btn.enabled = true; 					_root.cadence_btn._alpha = 100;					if(numPlaybackAttempts == numHearings) {						_root.play_btn.enabled = false						_root.play_btn._alpha = 50;					}					}									}				else if (success && _root.isPlaying) {					_root.instanceSound.stop();					_root.isPlaying = false;					_root.cadence_btn.enabled = true; 					_root.cadence_btn._alpha = 100;				}			};			_root.instanceSound.loadSound("media/audio/" + shuffledDrillFileList[currentDrillNum] + ".mp3", false);		}	}			static private function fillPlayProgressBar() {		// 6px high, 44px wide		_root.playback_attempts.beginFill(0xFF3300);		_root.playback_attempts.moveTo(0,0);		_root.playback_attempts.lineTo(44*(numPlaybackAttempts/numHearings),0);		_root.playback_attempts.lineTo(44*(numPlaybackAttempts/numHearings),6);		_root.playback_attempts.lineTo(0,6);		_root.playback_attempts.lineTo(0,0);		_root.playback_attempts.endFill;	}		static private function unfillPlayProgressBar() {		// 6px high, 44px wide		_root.playback_attempts.beginFill(0xFFFFFF);		_root.playback_attempts.moveTo(0,0);		_root.playback_attempts.lineTo(44,0);		_root.playback_attempts.lineTo(44,6);		_root.playback_attempts.lineTo(0,6);		_root.playback_attempts.lineTo(0,0);		_root.playback_attempts.endFill;	}		static private function playCadence() {				/*	AUG 26, 2009					Note to future development efforts:							The cadence sound file function now respects different keys (even though all examples 				are in C major as of Aug. 2009).							As long as other future cadence sound files are named as "Bf-major" for B-flat major, or 				as "Cs-minor" for "C-sharp minor", everything will work without any code modifications.		*/				var keyStr:String = shuffledDrillFileList[currentDrillNum].substr(8,2);		var cadSnd:String;				if(shuffledDrillFileList[currentDrillNum].substr(5,3) == "Maj") {			cadSnd = keyStr + "-" + "major";		}		else if (shuffledDrillFileList[currentDrillNum].substr(5,3) == "Min") {			cadSnd = keyStr + "-" + "minor";		}						_root.cadenceSound.onLoad = function(success:Boolean):Void {			if (success && !_root.cad_isPlaying) {				_root.instanceSound.stop();				_root.isPlaying = false;				_root.cadenceSound.start();				_root.cad_isPlaying = true;								_root.cadenceSound.onSoundComplete = function () {					_root.cad_isPlaying = false;				}							}			else if (success && _root.cad_isPlaying) {				_root.cadenceSound.stop();				_root.cad_isPlaying = false;			}		};				_root.cadenceSound.loadSound("media/audio/" + cadSnd + ".mp3", false);			}		static private function submitExample() {				// must check first to make sure that something is selected!		if(_root.drillGrid.selectedItem.data) {						var drillScore:Object = new Object();				// selectedIdiom:	the idiom that was selected as the drill example answer (eg, "1ab")				// correctIdiom:	the correct idiom for the the drill example answer (eg, "1aa")				// instance:		the instance name (eg, "1dc02MinCn")				// score: 			0 if incorrect, 1 if correct						var score:Number;			if(selectedIdiom == correctIdiom) {				score=1;			}			else {				score=0;			}			disableDrillButtons();			showAnswerText(score);						_root.cadenceSound.stop();			_root.cad_isPlaying = false;			_root.instanceSound.stop();			_root.isPlaying = false;				drillScore.selectedIdiom = selectedIdiom;			drillScore.correctIdiom = correctIdiom; 			drillScore.score = score;			drillScore.instance = shuffledDrillFileList[currentDrillNum];						drillScoreArray.push(drillScore);								calculateScore();			showImage();						//trace("drillScore.score: " + drillScore.score);			//trace("drillScoreArray.length: " + drillScoreArray.length);						_root.drill_response._visible = true;			// Setup Submit button			_root.drill_response.next_button.onRelease = function() {				_root.instanceSound.stop();				_root.isPlaying = false;				enableDrillButtons();				nextExample();			}		}		else {			trace("You must select something before pressing Submit.");		}	}			static private function disableDrillButtons() {		_root.play_btn.enabled = false;		_root.play_btn._alpha = 50;		_root.cadence_btn.enabled = false;		_root.cadence_btn._alpha = 50;		_root.drill_submit.enabled = false;		_root.playback_attempts._alpha = 50;	}		static private function enableDrillButtons() {		_root.play_btn.enabled = true;		_root.play_btn._alpha = 100;		_root.cadence_btn.enabled = true;		_root.cadence_btn._alpha = 100;		_root.drill_submit.enabled = true;		_root.playback_attempts._alpha = 100;	}		static private function showAnswerText(score:Number) {				var myStyle = new TextField.StyleSheet();		myStyle.onLoad = function(success:Boolean): Void {			_root.drill_response.drillResponse_correct.styleSheet = myStyle;			_root.drill_response.drillResponse_correct.html = true;			_root.drill_response.drillResponse_correct.embedFonts = true;						_root.drill_response.drillResponse_selected.styleSheet = myStyle;			_root.drill_response.drillResponse_selected.html = true;			_root.drill_response.drillResponse_selected.embedFonts = true;						if(score == 1) {				_root.drill_response.drillResponse_feedback1.text = "Correct!";				_root.drill_response.drillResponse_correct.text = correctIdiomText;				_root.drill_response.drillResponse_feedback2.text = "";				_root.drill_response.drillResponse_selected.text = "";			}			else {				_root.drill_response.drillResponse_feedback1.text = "No, the correct answer is:";				_root.drill_response.drillResponse_correct.text = correctIdiomText;				_root.drill_response.drillResponse_feedback2.text = "You selected:";				_root.drill_response.drillResponse_selected.text = selectedIdiomText;			}		};		myStyle.load("mycss.css");		_root.drill_response.next_button.setStyle("backgroundColor", 0xFF0000);	}			static private function showImage() {		_root.drill_response.createEmptyMovieClip("notation", 998);		_root.drill_response.notation._x = 30;		_root.drill_response.notation._y = 38;		_root.drill_response.notation.loadMovie("media/images/" + shuffledDrillFileList[currentDrillNum] + ".png");						_root.drill_response.play_answer.onRelease = function() {			playAnswer();		}	}			static private function playAnswer() {		if (!_root.isPlaying) {			_root.instanceSound.start();			_root.isPlaying = true;			_root.instanceSound.onSoundComplete = function () {				_root.isPlaying = false;			}					}		else if (_root.isPlaying) {			_root.instanceSound.stop();			_root.isPlaying = false;		}	}			static private function calculateScore() {				var correct = 0;				for(var z=0; z<drillScoreArray.length; z++) {						if(drillScoreArray[z].score == 1) {				correct++;			}		}						_root.drillscore_correct.text = correct + "/" + drillScoreArray.length;		_root.drillscore_percent.text =  Math.round((correct / drillScoreArray.length) * 100) + "%";	}			static private function nextExample() {				currentDrillNum++;		numPlaybackAttempts = 0;		unfillPlayProgressBar();		_root.num_hearings.text = "0/" + numHearings;				if(currentDrillNum == shuffledDrillFileList.length) {			currentDrillNum = 0;			shuffledDrillFileList = shuffleDrillList(drillFileList);			//trace("shuffling from nextExample(): " + shuffledDrillFileList);		}				_root.drillGrid.selectedIndex = undefined; // remove selection in drillGrid		_root.drill_response._visible = false;				_root.drill_submit.enabled = false;				if(auto_play) {playExample();}	}		static private function exitDrill() {				_root.instanceSound.stop();		_root.isPlaying = false;		_root.cadenceSound.stop();		_root.cad_isPlaying = false;						// if I decide to keep past drill attempts for the purposes of preparing a report		// of all drills, scores, details, etc., THIS is the place to push the drillScoreArray		// somewhere (probably to a new class).  I tried pushing it to another array, but was		// unsuccessful in getting it to parse with the "uberDrillScoreArray[i][j].score" syntax.				drillScoreArray.splice(0);		gotoAndStop(2);	}		static private function shuffleDrillList(array:Array):Array {		var array_length:Number = array.length;		var mixed:Array = array.slice();		var rn:Number;		var it:Number;		var el:Object;				for (it = 0; it<array_length; it++) {			el = mixed[it];			mixed[it] = mixed[rn = random(array_length)];			mixed[rn] = el;		}		return mixed;	}			}
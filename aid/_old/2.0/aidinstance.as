class aidinstance {		var selInstance:XMLNode;	var instanceNode:XMLNode;		static var selectedInstance:String;		static var imageArray:Array = new Array();	static var columnArray:Array = new Array();		// constructor	function aidinstance(inst:XMLNode) {		_root.major_header._visible = true;		_root.minor_header._visible = true;		_root.click_instructions._visible = true;		selInstance = inst;		this.drawNotationImage();	}			function drawNotationImage() {		imageArray.splice(0);		columnArray.splice(0);						var column:Number = 0;		var i:Number = 1;				// load the instance image files into the imageArray array		for (instanceNode = selInstance; instanceNode != null; column++, i++) {						// col 1; should be MAJOR			if(i%2 != 0) { 				if(instanceNode.attributes.id.substr(5,3) == "Maj") {					imageArray.addItem({Column:column, Examples:"media/images/" + instanceNode.attributes.id + ".png", data:instanceNode});					instanceNode = instanceNode.nextSibling;										// if that was the LAST instance, pad the Minor column					// with the "no minor" for this instance to balance the grid					if(instanceNode == null) {						imageArray.addItem({Column:column, Examples:"media/images/no-minor-instance.png", data:"no_instance"});					}				}				else {					imageArray.addItem({Column:column, Examples:"media/images/no-major-instance.png", data:"no_instance"});				}			}						// col 2; should be MINOR			else {				if(instanceNode.attributes.id.substr(5,3) == "Min") {					imageArray.addItem({Column:column, Examples:"media/images/" + instanceNode.attributes.id + ".png", data:instanceNode});					instanceNode = instanceNode.nextSibling;				}				else {					imageArray.addItem({Column:column, Examples:"media/images/no-minor-instance.png", data:"no_instance"});				}			}					//trace("inode: " + instanceNode);			column=column%3; // 0-2		}				// spread the instance images across two columns in the dataGrid		for(i=0; i<imageArray.length; i=i+2) {			columnArray.addItem({col1_img:imageArray[i].Examples, col2_img:imageArray[i+1].Examples, col1_data:imageArray[i].data, col2_data:imageArray[i+1].data});		}				_root.notationGrid.dataProvider = columnArray;				// data grid cleanup		_root.notationGrid.removeColumnAt(_root.notationGrid.getColumnIndex("col1_data"));		_root.notationGrid.removeColumnAt(_root.notationGrid.getColumnIndex("col2_data"));				_root.notationGrid.setStyle("rollOverColor", 0xFFFFFF); // 0xCCEBFF		_root.notationGrid.setStyle("selectionColor", 0xFFFFFF); // 0xFFFFCC				_root.notationGrid.getColumnAt(0).width = 291;		_root.notationGrid.getColumnAt(1).width = 291;		_root.notationGrid.getColumnAt(2).width = 0;		_root.notationGrid.getColumnAt(3).width = 0;				_root.notationGrid.getColumnAt(0).cellRenderer = "imageCellRender";		_root.notationGrid.getColumnAt(1).cellRenderer = "imageCellRender";				// this line is necessary because 'this.playSound()' will not work				var owner:aidinstance = this;				// user clicked on notation graphic in dataGrid		var listenerObject = new Object();		listenerObject.cellPress = function(evt_obj:Object){			//trace("column " + evt_obj.columnIndex + " :: " + "row " + evt_obj.itemIndex);			//trace(evt_obj.target.selectedItem.data.attributes.id);						// first column			if(evt_obj.columnIndex %2 == 0) {				selectedInstance = columnArray[evt_obj.itemIndex].col1_data.attributes.id;				if(columnArray[evt_obj.itemIndex].col1_data != "no_instance") {					owner.playSound();				}				else {trace("no_instance");}			}			// second column			else {				selectedInstance = columnArray[evt_obj.itemIndex].col2_data.attributes.id;				if(columnArray[evt_obj.itemIndex].col2_data != "no_instance") {					owner.playSound();				}			}		}		_root.notationGrid.addEventListener("cellPress", listenerObject);			}			function stopSound() {		_root.instanceSound.stop();		_root.isPlaying = false;	}			function playSound() {		_root.instanceSound.onLoad = function(success:Boolean):Void {			if (success && !_root.isPlaying && !_root.ignorePlaybackRequests) {				_root.instanceSound.start();				_root.isPlaying = true;				trace("playing: " + selectedInstance);								_root.instanceSound.onSoundComplete = function () {					_root.isPlaying = false;				}							}			else if (success && _root.isPlaying) {				_root.instanceSound.stop();				//trace("stop in playSound: ");				//trace(_root.ignorePlaybackRequests);				_root.isPlaying = false;			}		};		_root.instanceSound.loadSound("media/audio/" + selectedInstance + ".mp3", false);	}		}
class aiddata {	static private var aidXML:XML = new XML();	static private var drillXML:XML = new XML();		static private var hilightColor:Number = 0xFFFFCC;		static private var instance:aidinstance;		static private var drillTopicNode:XMLNode;	static private var idiomNode:XMLNode;	static private var drillNameNode:XMLNode;	static private var selectedDrill:XMLNode;		static private var idiomArray:Array = new Array();	static private var idiomDrillsArray:Array = new Array();	static private var idiomDrillsGridArray:Array = new Array();		static var levelComboListener:Object = new Object();	static var topicComboListener:Object = new Object();	static var idiomGridListener:Object = new Object();	static var drillsButtonListener:Object = new Object();	static var drillsDialogOkListener:Object = new Object();	static var drillsDialogCancelListener:Object = new Object();	static var rbListener:Object = new Object(); 		static var topicName:String;	static var drillFileList:Array = new Array();		static var selLevel:XMLNode;	static var selLevelIndex:Number;	static var selTopic:XMLNode;	static var selTopicIndex:Number;		static var freshStart:Boolean = true;	/*  *************************************		GET THE XML				************************************ */	function aiddata() {		aidXML.ignoreWhite = true;		aidXML.onLoad = function(success:Boolean) {			if (success) {				//trace("got the aid xml");								drillXML.ignoreWhite = true;				drillXML.onLoad = function(success:Boolean) {					if (success) {						//trace("got the drills xml");						_root.gotoAndStop(2);					} 					else {						trace("error loading drill XML");					}				};						drillXML.load("drills.xml");			} 			else {				trace("error loading aid XML");			}		};				aidXML.load("aid-data.xml");	}		/*  *************************************		LEVELS				************************************ */			public function getLevels():Void {				var levelNode:XMLNode = aidXML.firstChild.firstChild;				_root.topicCombo.enabled = false;		_root.levelCombo.addItem({data:0, label:"Select a Level..."});				for ( ; levelNode != null; levelNode = levelNode.nextSibling) {			if(levelNode.nodeName == "level") {				// trace("adding level: " + levelNode.attributes.label);				_root.levelCombo.addItem({data:levelNode, label:levelNode.attributes.label});			}		}				_root.levelCombo.setStyle("backgroundColor", hilightColor);				levelComboListener.change = function (evt_obj:Object) {			// trace("Currently selected level is: " + evt_obj.target.selectedItem.label);						_root.topicCombo.removeAll();			_root.topicCombo.enabled = false;			_root.topicCombo.setStyle("backgroundColor", 0xFFFFFF);			_root.selTopicIndex = null;			_root.selTopic = null;						//trace("selTopicIndex: " + selTopicIndex);			clearIdiomsAndExamples();						if(evt_obj.target.selectedItem.data == 0) {				_root.topicCombo.enabled = false;				_root.levelCombo.setStyle("backgroundColor", hilightColor);			}			else {								freshStart = true;				_root.topicCombo.enabled = true;				_root.levelCombo.setStyle("backgroundColor", 0xFFFFFF);				_root.topicCombo.setStyle("backgroundColor", hilightColor);								selLevel = evt_obj.target.selectedItem.data;				selLevelIndex = evt_obj.target.selectedIndex;								getTopics(selLevel);			}		}		_root.levelCombo.addEventListener("change", levelComboListener);				if (selLevel) {			_root.levelCombo.selectedIndex = selLevelIndex;			_root.levelCombo.setStyle("backgroundColor", 0xFFFFFF);			_root.topicCombo.enabled = true;			freshStart = false;			getTopics(selLevel);		}		//trace("selTopicIndex: " + selTopicIndex);	}		/*  *************************************		TOPICS				************************************ */	static public function getTopics(levelNode:XMLNode):Void {						var topicNode:XMLNode = levelNode.firstChild;				_root.topicCombo.removeAll();		_root.topicCombo.addItem({data:0, label:"Select a Topic..."});		for ( ; topicNode != null; topicNode = topicNode.nextSibling) {			if(topicNode.nodeName == "topic") {				_root.topicCombo.addItem({data:topicNode, label:topicNode.attributes.label});			}		}				topicComboListener.change = function (evt_obj:Object) {			// trace("Currently selected topic is: " + evt_obj.target.selectedItem.label);						clearIdiomsAndExamples();			if(evt_obj.target.selectedItem.data == 0) {				trace("selected topic has no data");				_root.topicCombo.setStyle("backgroundColor", hilightColor);			}			else {				_root.topicCombo.setStyle("backgroundColor", 0xFFFFFF);								selTopic = evt_obj.target.selectedItem.data;				selTopicIndex = evt_obj.target.selectedIndex;				getIdioms(selTopic);								drillTopicNode = drillXML.firstChild.firstChild;				//trace("selected topic is: " + evt_obj.target.selectedItem.data.attributes.id);								for(; drillTopicNode != null; drillTopicNode = drillTopicNode.nextSibling) {					if (evt_obj.target.selectedItem.data.attributes.id == drillTopicNode.attributes.id) {						break;					}				}				if(drillTopicNode.attributes.id == undefined) {					//trace("4b or 4c detected"); // these two have no drills					_root.drills._visible = false;				}				else {					_root.drills._visible = true;					_root.drills.enabled = true;					drillsButtonListener.click = function() {						setupDrillsDialog(evt_obj.target.selectedItem.label);					};					_root.drills.addEventListener("click", drillsButtonListener);				}			}		}		_root.topicCombo.addEventListener("change", topicComboListener);				//trace("selTopicIndex: " + selTopicIndex);		//trace("selTopic: " + selTopic);				if (selTopic && !freshStart) {			_root.topicCombo.selectedIndex = selTopicIndex;			_root.topicCombo.setStyle("backgroundColor", 0xFFFFFF);						_root.drills.enabled = true;			drillsButtonListener.click = function() {				setupDrillsDialog(_root.topicCombo.selectedItem.label);			};			_root.drills.addEventListener("click", drillsButtonListener);						getIdioms(selTopic);		}	}			static private function setupDrillsDialog(topic_name:String) {				topicName = topic_name;		_root.levelCombo.enabled = false;		_root.topicCombo.enabled = false;		_root.idiomGrid.enabled = false;		//_root.notationGrid.enabled = false; // this doesn't work so am using workaround with ignorePlaybackRequests		_root.ignorePlaybackRequests = true;		_root.drillDialog.num_hearings_alert._visible = false;		_root.drillDialog._visible = true;				_root.instanceSound.stop();		_root.isPlaying = false;						//trace("\rdrillTopicNode is: " + drillTopicNode.attributes.id);				// NOTE that 4b and 4c have no drills defined		// so drillTopicNode.attributes.id will return "undefined" for these two.  		// We should display an alert or something that reads:		// 		// "The selected topic contains no drills."						// Create Radio Buttons		if(drillTopicNode.attributes.id) {			drillNameNode = drillTopicNode.firstChild;						for(var i:Number=0; drillNameNode != null; drillNameNode = drillNameNode.nextSibling, i++) {				//trace(drillNameNode.attributes.name);				//_root.drillDialog.createClassObject(mx.controls.RadioButton, "drill"+i, 10+i, {label:drillNameNode.attributes.name, groupName:"selectDrillGroup", data:drillNameNode, _x:120, _y:174+(i*30), _width:400, _height:29});				_root.drillDialog.createClassObject(mx.controls.RadioButton, "drill"+i, 10+i, {label:"", groupName:"selectDrillGroup", data:drillNameNode, _x:140, _y:176+(i*32), _width:20, _height:20});				_root.drillDialog.createClassObject(mx.controls.TextArea, "texta"+i, 30+i, {text:drillNameNode.attributes.name, _x:160, _y:174+(i*32), _width:330, _height:40, borderStyle: "none", wordWrap: true});			}		}		else {			trace("The selected topic contains no drills.");		}				// Radio button listener		rbListener.click = function(evt_obj:Object){		   selectedDrill = evt_obj.target.selection.data;		   //trace(selectedDrill);		} 		_root.drillDialog.selectDrillGroup.addEventListener("click", rbListener); 								// OK Button for Drills Dialog		drillsDialogOkListener.click = function() {						idiomDrillsArray.splice(0);			idiomDrillsGridArray.splice(0);			drillFileList.splice(0);					if(selectedDrill && _root.drillDialog.num_hearings.text) {								getDrillFileList(selectedDrill, drillFileList, idiomDrillsArray);								//trace("idiomDrillsArray: " + idiomDrillsArray);								loadDrillIdiomFiles();								//trace("idiomDrillsGridArray: " + idiomDrillsGridArray);								// !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!								/*								passing idiomDrillsGridArray												MAJOR BUG FIX ON SEPT 1, 2009								*/											}			else {				if(!_root.drillDialog.num_hearings.text) {					_root.drillDialog.num_hearings_alert._visible = true;					_root.drillDialog.num_hearings.text.setFocus();					_root.drillDialog.num_hearings.setStyle("backgroundColor", 0xFF3333);				}				//trace("Select a drill and enter a number (1-9) for the number of times an example can be played.");			}		}		_root.drillDialog.drill_ok.addEventListener("click", drillsDialogOkListener);						// Cancel Button for Drills Dialog		drillsDialogCancelListener.click = function() {			_root.drillDialog.num_hearings.setStyle("backgroundColor", 0xFFFFFF);			_root.drillDialog._visible = false;			_root.levelCombo.enabled = true;			_root.topicCombo.enabled = true;			_root.idiomGrid.enabled = true;			//_root.notationGrid.enabled = true;			_root.ignorePlaybackRequests = false;						// delete all radio buttons and text fields			drillNameNode = drillTopicNode.firstChild;			for(var i:Number=0; drillNameNode != null; drillNameNode = drillNameNode.nextSibling, i++) {				_root.drillDialog.destroyObject("drill"+i);				_root.drillDialog.destroyObject("texta"+i);			}			selectedDrill = null;		}		_root.drillDialog.drill_cancel.addEventListener("click", drillsDialogCancelListener);				// Num Hearings textinput box		_root.drillDialog.num_hearings.maxChars = 1;		_root.drillDialog.num_hearings.restrict = "1-9";	}		static private function getDrillFileList(selDrill:XMLNode, drillList:Array) {				var idiomStr:String;				// populate array with list of files for drill and pass along to new aiddrill								for(var i=0; i<selDrill.childNodes.length; i++) {			idiomStr = selDrill.childNodes[i].firstChild.nodeValue;						idiomDrillsArray.push(idiomStr);					var levelNode:XMLNode = aidXML.firstChild.firstChild;			for ( ; levelNode != null; levelNode = levelNode.nextSibling) {				if(levelNode.attributes.id == idiomStr.charAt(0)) {					break;				}			}						var topicNode:XMLNode = levelNode.firstChild;			for ( ; topicNode != null; topicNode = topicNode.nextSibling) {				if(topicNode.attributes.id.charAt(1) == idiomStr.charAt(1)) {					break;				}			}						var idiomNode:XMLNode = topicNode.firstChild;			for ( ; idiomNode != null; idiomNode = idiomNode.nextSibling) {				if(idiomNode.attributes.id == idiomStr) {					break;				}			}						var instanceNode:XMLNode = idiomNode.firstChild;			for ( ; instanceNode != null; instanceNode = instanceNode.nextSibling) {				drillList.push(instanceNode.attributes.id);			}		}	}			/*  *************************************		IDIOMS				************************************ */	static private function getIdioms(topicNode:XMLNode):Void {		idiomNode = topicNode.firstChild;						_root.idiomGrid.removeAllColumns();		_root.idiomGrid.removeAll();		_root.idiomGrid.columnNames = ["data", "label"];				_root.idiomGrid.setStyle("rollOverColor", 0xCCEBFF);		_root.idiomGrid.setStyle("selectionColor", hilightColor);		HtmlCellRenderer.CssUrl = "mycss.css";		_root.idiomGrid.embedFonts = true;						var col:mx.controls.gridclasses.DataGridColumn;		col = _root.idiomGrid.getColumnAt(1);		col.width = 565;		col.headerText = "label";		col.cellRenderer = "HtmlCellRenderer";						// populate the fileList array with names of the analysis .txt files to render idiom list		var fileList:Array = new Array();				for ( ; idiomNode != null; idiomNode = idiomNode.nextSibling) {			if(idiomNode.nodeName == "idiom") {				fileList.addItem({fileString:"analysis/" + idiomNode.attributes.id + ".txt", data:idiomNode});			}		}		fileList.sortItemsBy("fileString", "ASC"); // this shouldn't be necessary				// clear the idiomArray		idiomArray.splice(0);		/*		// step through the fileList array and load each file's data via the loadFile() function		for(var i=0; i<fileList.length; i++) {			loadFile(fileList[i]);		}				*/				loadFiles(fileList);				// ideally, I would sort on arr.data.attributes.id		//_root.idiomArray.sortItemsBy("data","ASC");  // this doesn't seem to have any effect; I think loadVars has not finished its work by the time this is called		_root.idiomGrid.dataProvider = idiomArray;				// grid cleanup		_root.idiomGrid.removeColumnAt(_root.idiomGrid.getColumnIndex("data"));		_root.idiomGrid.setStyle("alternatingRowColors", Array(0xFFFFFF, 0xF7F7F7));		_root.idiomGrid.rowHeight = 28;								idiomGridListener.change = function (evt_obj:Object) {			//trace("Selected idiom is: " + evt_obj.target.selectedItem.data);						if(evt_obj.target.selectedItem.data == 0) {				trace("selected idiom has no data");			}			else {				_root.instanceSound.stop();				_root.isPlaying = false;				getInstances(evt_obj.target.selectedItem.data);			}		}		_root.idiomGrid.addEventListener("change", idiomGridListener)	}		/*  *************************************		INSTANCES				aidinstance is defined in:		aidinstance.as		************************************ */	static private function getInstances(idiomNode:XMLNode):Void {		if(_root.idiomGrid.selectedItem.data.attributes.id) {			instance = new aidinstance(idiomNode.firstChild);		}		else {			// the idiomGrid selected item was unselected			_root.notationGrid.removeAllColumns();			_root.notationGrid.removeAll();		}	}		/*  *************************************		CLEAR THE GRIDS				************************************ */	static private function clearIdiomsAndExamples() {		_root.idiomGrid.removeAllColumns();		_root.idiomGrid.removeAll();				_root.notationGrid.removeAllColumns();		_root.notationGrid.removeAll();				_root.major_header._visible = false;		_root.minor_header._visible = false;		_root.click_instructions._visible = false;				_root.instanceSound.stop();		_root.isPlaying = false;				_root.drills._visible = true; // just in case it was hidden in 4b/4c selection		_root.drills.enabled = false;	}				static function loadDrillIdiomFiles() {		var fileNum:Number = 0;		var myLoadVar:LoadVars = new LoadVars();				var drill4a2Array:Array = new Array("4aa-4ad","4ae-4ah","4ai-4al"); // this is the exception drill which has a reduced number of drill answer choices				if(idiomDrillsArray[0] == "4aa" && idiomDrillsArray.length == 12) {			//trace("Found 4a drill #2!");							myLoadVar.onData = function (src:String):Void {				if (src != undefined) {					idiomDrillsGridArray.addItem({data:drill4a2Array[fileNum], label:src});					//trace("4a2: " + drill4a2Array[fileNum]);				}				else {					trace("error loading drill idiom file"); 				}				// found this trick here: http://forums.devshed.com/flash-help-38/loadvars-within-a-loop-498803.html								fileNum++;								if(fileNum < drill4a2Array.length) {					this.load("analysis/" + drill4a2Array[fileNum] + ".txt");				}				else {					// this has to go here so that we make sure all files are loaded first					var drill:aiddrill = new aiddrill(selectedDrill, idiomDrillsGridArray, topicName, drillFileList, _root.drillDialog.num_hearings.text);				}			}			myLoadVar.load("analysis/" + drill4a2Array[0] + ".txt");														}						else {			myLoadVar.onData = function (src:String):Void {				if (src != undefined) {					idiomDrillsGridArray.addItem({data:idiomDrillsArray[fileNum], label:src});					//trace("idiomDrillsArray[fileNum]: " + idiomDrillsArray[fileNum]);				}				else {					trace("error loading drill idiom file"); 				}				// found this trick here: http://forums.devshed.com/flash-help-38/loadvars-within-a-loop-498803.html								fileNum++;								if(fileNum < idiomDrillsArray.length) {					this.load("analysis/" + idiomDrillsArray[fileNum] + ".txt");				}				else {					// this has to go here so that we make sure all files are loaded first					var drill:aiddrill = new aiddrill(selectedDrill, idiomDrillsGridArray, topicName, drillFileList, _root.drillDialog.num_hearings.text);				}			}			myLoadVar.load("analysis/" + idiomDrillsArray[0] + ".txt");		}	}			 	static function loadFiles(arr:Array) {				var fileNum:Number = 0;		var myLoadVar:LoadVars = new LoadVars();						myLoadVar.onData = function (src:String):Void {			if (src != undefined) {								// use for debugging: appends idiom id (eg, "2ba: ") to idiomGrid rows				//src = prependIdiomId(src, arr[fileNum].data.attributes.id);												// check for comparison idiom				if(arr[fileNum].data.attributes.type == "comparison") {										// slice off the opening <p> tag					var truncatedString:String = src;					truncatedString.slice(3, truncatedString.length);										// prepare the string to be prepended					var comparisonString:String = "<p><span class ='txt'>FOR COMPARISON: </span>";										// concat the strings					src = comparisonString + truncatedString;					 					//_root.idiomGrid.addItem({data:arr.data, Idioms:src});					idiomArray.addItem({data:arr[fileNum].data, label:src});				}				else {					//_root.idiomGrid.addItem({data:arr.data, Idioms:src});					idiomArray.addItem({data:arr[fileNum].data, label:src});				}			}			else {				trace("error loading text into grid"); 			}									// found this trick here:			// http://forums.devshed.com/flash-help-38/loadvars-within-a-loop-498803.html						fileNum++;						if(fileNum < arr.length) {				this.load(arr[fileNum].fileString);			}					}		myLoadVar.load(arr[0].fileString);	}		static function prependIdiomId(str:String, idiomId:String):String {		// slice off the <p> tag at the beginning		str.slice(3, str.length);				// prepare the idiom id to prepend		var idiomIdBlock:String = "<p><span class ='txt'>" + idiomId + ": </span>";				// concat the strings		str = idiomIdBlock + str;				return(str);	}		}